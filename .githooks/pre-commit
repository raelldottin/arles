#!/usr/bin/env bash

set -euo pipefail

if [[ ! -x ".venv/bin/ruff" ]]; then
  echo "Missing development tools. Run '.venv/bin/python -m pip install -e .[dev]'."
  exit 1
fi

.venv/bin/ruff check .
.venv/bin/pyright
.venv/bin/pytest -m "not integration"
.venv/bin/shellcheck bin/process_directory.sh bin/process_torrent.sh .githooks/pre-commit
